# E2E Test Credentials
# Copy this file to .env.test.local and fill in real values.
# NEVER commit .env.test.local to source control.
#
# Default values below work for a freshly installed local dev environment.
# The e2e-admin@example.com user is created by the setup script in global-setup.ts.

# The base URL of the running application (Next.js dev or prod)
E2E_BASE_URL=http://localhost:3000

# Backend API URL (used for direct API calls in global-setup)
E2E_API_URL=http://localhost:1338/api/v1

# ── Admin user (must already exist with admin role) ─────────────────────────
E2E_ADMIN_EMAIL=e2e-admin@example.com
E2E_ADMIN_PASSWORD=E2eAdmin1234!

# ── Teacher user (will be created + granted instructor role) ─────────────────
E2E_TEACHER_EMAIL=e2e-teacher@example.com
E2E_TEACHER_PASSWORD=Teacher1234!
E2E_TEACHER_FIRST_NAME=Eve
E2E_TEACHER_LAST_NAME=Teach

# ── Student user (will be created as a regular user) ────────────────────────
E2E_STUDENT_EMAIL=e2e-student@example.com
E2E_STUDENT_PASSWORD=Student1234!
E2E_STUDENT_FIRST_NAME=Sam
E2E_STUDENT_LAST_NAME=Learn

# ── Role slug for teacher role in this platform installation ─────────────────
# Run: curl -s http://localhost:1338/api/v1/roles (auth required) to list slugs
E2E_TEACHER_ROLE_SLUG=instructor

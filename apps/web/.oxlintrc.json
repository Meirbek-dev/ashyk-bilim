{
  "$schema": "./node_modules/oxlint/configuration_schema.json",

  "categories": {
    "correctness": "error",
    "nursery": "warn",
    "pedantic": "off",
    "perf": "error",
    "restriction": "warn",
    "style": "warn",
    "suspicious": "error"
  },

  "env": {
    "builtin": true,
    "browser": true,
    "es2024": true,
    "node": true
  },

  "globals": {},

  "ignorePatterns": [
    ".git/",
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/tests/",
    "**/*.js",
    "**/*.mjs",
    "**/cdk.out/",
    "**/dist/",
    "**/node_modules/",
    "**/bp_modules/",
    "**/.botpress/",
    "**/gen/",
    "**/.turbo/",
    "**/.genenv/",
    "lib/api/generated/schema.ts",
    "e2e/",
    "scripts/",
    "playwright.config.ts",
    "eslint.config.*",
    "src/components/providers/session-provider.tsx",
    "src/features/assessments/registry/code-challenge/hooks.ts",
    "src/features/assessments/shell/AssessmentLayout.tsx",
    "src/features/assessments/registry/code-challenge/hooks.ts",
    "src/components/Security/HeaderProfileBox.tsx",
    "src/features/assessments/studio/NativeItemStudio.tsx",
    "src/services/gamification/server.ts",
  ],

  "plugins": [
    "import",
    "jsdoc",
    "jsx-a11y",
    "nextjs",
    "node",
    "oxc",
    "promise",
    "react",
    "react-perf",
    "typescript",
    "unicorn"
  ],

  "rules": {
    "no-shadow": "warn",
    "typescript/no-explicit-any": "warn",
    /* ── Noisy / pedantic — keep off ──────────────────────────── */
    "arrow-body-style": "off",
    "capitalized-comments": "off",
    "complexity": "off",
    "curly": "off",
    "default-case": "off",
    "func-style": "off",
    "id-length": "off",
    "init-declarations": "off",
    "max-lines": "off",
    "max-params": "off",
    "max-statements": "off",
    "new-cap": "off",
    "no-await-in-loop": "off",
    "no-console": "off",
    "no-constant-condition": "off",
    "no-debugger": "off",
    "no-duplicate-imports": "off", // handled by import/no-duplicates
    "no-empty-function": "off",
    "no-empty-pattern": "off",
    "no-implicit-coercion": "off",
    "no-magic-numbers": "off",
    "no-nested-ternary": "off",
    "no-null": "off",
    "no-relative-parent-imports": "off",
    "no-ternary": "off",
    "no-undefined": "off",
    "no-use-before-define": "off",
    "no-var": "off",
    "no-void": "off",
    "prefer-template": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "vars-on-top": "off",
    "yoda": "off",
    "no-optional-chaining": "off",
    "no-rest-spread-properties": "off",
    "class-methods-use-this": "off",

    /* ── Correctness aligned with tsconfig ─────────────────────── */
    // tsconfig: allowUnreachableCode: false
    "no-unreachable": "error",
    // tsconfig: noUnusedLocals / noUnusedParameters — lint layer catches JS files
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],

    /* ── Token efficiency & agentic cleanliness ────────────────── */
    "no-extra-boolean-cast": "error",
    "no-regex-spaces": "error",
    "no-useless-catch": "error",
    "no-useless-computed-key": "error",
    "no-useless-concat": "error",
    "no-useless-rename": "error",
    "object-shorthand": "error",

    /* ── Oxc plugin ────────────────────────────────────────────── */
    "oxc/no-async-await": "off",

    /* ── Import plugin ─────────────────────────────────────────── */
    "import/no-default-export": "off",
    "import/no-named-export": "off",
    "import/no-unassigned-import": "off",
    "import/prefer-default-export": "off",
    "import/group-exports": "off",
    "import/exports-last": "off",
    "import/no-namespace": "off",
    "import/no-duplicates": "error",
    "import/no-self-import": "error",
    // Tiptap and other packages export both default and named — false positive
    "import/no-named-as-default": "off",

    /* ── TypeScript plugin ─────────────────────────────────────── */
    // verbatimModuleSyntax: true requires import type for type-only imports
    "typescript/consistent-type-imports": ["error", { "prefer": "type-imports", "fixStyle": "inline-type-imports" }],
    "typescript/no-import-type-side-effects": "error",
    // Unused vars handled by TS compiler; keep off to avoid double-reporting
    "typescript/no-unused-vars": "off",
    // Strictness
    "typescript/no-extra-non-null-assertion": "error",
    "typescript/no-unnecessary-type-constraint": "error",
    "typescript/no-non-null-asserted-optional-chain": "error",
    // Keep permissive — TS strict mode covers these at compile time
    "typescript/explicit-function-return-type": "off",
    "typescript/explicit-module-boundary-types": "off",
    "typescript/no-floating-promises": "off",
    "typescript/no-misused-promises": "off",
    "typescript/no-unnecessary-condition": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/prefer-readonly-parameter-types": "off",
    "typescript/promise-function-async": "off",
    "typescript/strict-void-return": "off",
    "typescript/consistent-return": "off",
    // Type-level rules — handled by tsc, too noisy in oxlint
    "typescript/no-base-to-string": "off",
    "typescript/restrict-template-expressions": "off",
    "typescript/no-redundant-type-constituents": "off",
    "typescript/no-unsafe-enum-comparison": "off",
    "typescript/no-misused-spread": "off",

    /* ── React plugin ──────────────────────────────────────────── */
    "react/react-in-jsx-scope": "off", // react-jsx transform, no import needed
    "react/button-has-type": "off",
    "react/iframe-missing-sandbox": "off",
    "react/jsx-filename-extension": "off",
    "react/jsx-handler-names": "off",
    "react/jsx-max-depth": "off",
    "react/jsx-props-no-spreading": "off",
    "react/no-array-index-key": "off",
    "react/no-clone-element": "off",
    "react/no-danger": "off",
    "react/no-multi-comp": "off",
    "react/no-react-children": "off",
    "react/only-export-components": "off",
    "react/forbid-component-props": "off",
    // Allow component definitions passed as props (render props, component maps)
    "react/no-unstable-nested-components": ["error", { "allowAsProps": true }],

    /* ── React Perf plugin ─────────────────────────────────────── */
    "react-perf/jsx-no-new-array-as-prop": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "react-perf/jsx-no-jsx-as-prop": "off",

    /* ── Promise plugin ────────────────────────────────────────── */
    "promise/prefer-await-to-callbacks": "off",
    "promise/prefer-await-to-then": "off",
    "promise/no-promise-in-callback": "off",
    "promise/avoid-new": "off",

    /* ── Unicorn plugin ────────────────────────────────────────── */
    "unicorn/filename-case": "off",
    "unicorn/no-array-reduce": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-null": "off",
    "unicorn/prefer-string-raw": "off",
    "unicorn/prefer-array-find": "error",
    "unicorn/prefer-includes": "error",
    "unicorn/consistent-function-scoping": "off",

    /* ── JSX A11Y plugin — disable rules requiring large refactors ── */
    "jsx-a11y/prefer-tag-over-role": "off",
    "jsx-a11y/click-events-have-key-events": "off",
    "jsx-a11y/no-static-element-interactions": "off",
    "jsx-a11y/no-noninteractive-element-interactions": "off",
    "jsx-a11y/label-has-associated-control": "off",
    "jsx-a11y/control-has-associated-label": "off",
    "jsx-a11y/media-has-caption": "off",

    /* ── Disable underscore dangle — _prefix convention is valid ── */
    "no-underscore-dangle": "off",

    /* ── Next.js ─────────────────────────────────────────────────── */
    "nextjs/no-assign-module-variable": "off",

    /* ── JSDoc ───────────────────────────────────────────────────── */
    "jsdoc/check-tag-names": "off",

    /* ── Disable stylistic and pedantic rules with false-positives ─ */
    "typescript/no-non-null-assertion": "off",
    "unicorn/no-array-for-each": "off",
    "node/no-process-env": "off",
    "prefer-destructuring": "off",
    "no-continue": "off",
    "react/hook-use-state": "off",
    "unicorn/no-await-expression-member": "off",
    "no-bitwise": "off",
    "typescript/no-invalid-void-type": "off",
    "unicorn/no-document-cookie": "off",
    "oxc/no-barrel-file": "off",
    "unicorn/prefer-ternary": "off",
    "typescript/no-dynamic-delete": "off",
    "default-param-last": "off",
    "no-param-reassign": "off",
    "promise/param-names": "off",
    "promise/no-nesting": "off",
    "import/first": "off"
  },

  "settings": {}
}

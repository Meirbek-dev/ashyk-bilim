{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn",
    "nursery": "off",
    "restriction": "off",
    "style": "off",
    "pedantic": "off"
  },

  "env": {
    "builtin": true,
    "browser": true,
    "es2024": true,
    "node": true
  },

  "plugins": [
    "import",
    "jsdoc",
    "jsx-a11y",
    "nextjs",
    "node",
    "oxc",
    "promise",
    "react",
    "react-perf",
    "typescript",
    "unicorn"
  ],

  "ignorePatterns": [
    ".git/",
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.js",
    "**/cdk.out/",
    "**/dist/",
    "**/node_modules/",
    "**/bp_modules/",
    "**/.botpress/",
    "**/gen/",
    "**/. turbo/",
    "**/.genenv/",
    "packages/llmz/examples/",
    "lib/api/generated/schema.ts"
  ],

  "rules": {
    /* ── Correctness / suspicious exceptions ─────────────────────────
       These are in warn categories but are intentional patterns here.  */
    "no-await-in-loop": "off", // intentional in CLI/batch code
    "no-constant-condition": "off", // used for while-true loops
    "no-empty-pattern": "off",
    "no-thenable": "off",
    "no-unused-vars": "off", // delegated to tsconfig noUnusedLocals
    "typescript/no-unused-vars": "off",

    /* ── Agentic: async safety ───────────────────────────────────────
       Unhandled promises are the #1 silent failure in LLM-generated code */
    "typescript/no-floating-promises": "warn",
    "typescript/no-misused-promises": "warn",

    /* ── Agentic: dead code / dead types ─────────────────────────────
       Catches unreachable branches and zombie type annotations          */
    "typescript/no-unnecessary-condition": "warn",
    "typescript/no-unnecessary-type-constraint": "warn",
    "typescript/no-extra-non-null-assertion": "warn",

    /* ── Token efficiency: useless syntax ────────────────────────────
       Code that compiles identically with fewer tokens                  */
    "no-useless-catch": "warn",
    "no-useless-computed-key": "warn",
    "no-useless-concat": "warn",
    "no-useless-rename": "warn",
    "no-useless-return": "warn",
    "no-extra-boolean-cast": "warn",

    /* ── Token efficiency: prefer concise built-ins ──────────────────
       Pulled from off categories, so need explicit enables              */
    "object-shorthand": "warn",
    "unicorn/prefer-array-find": "warn",
    "unicorn/prefer-includes": "warn",
    "import/no-duplicates": "warn",
    "import/no-self-import": "warn"
  }
}

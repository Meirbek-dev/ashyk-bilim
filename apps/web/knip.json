{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "entry": ["src/app/**/*.{ts,tsx}", "src/pages/**/*.{ts,tsx}", "src/i18n/navigation.ts"],
  "project": ["src/**/*.{ts,tsx,mjs}"],
  "ignore": [
    "e2e/**/*",
    "scripts/**/*",
    "src/components/ui/**/*",
    "src/components/DevScriptLoader.tsx",
    "src/components/Objects/Activities/DynamicCanva/AI/AICanvaToolkit.tsx"
  ],
  "ignoreDependencies": ["sharp", "shadcn", "tw-animate-css", "tailwindcss"],
  "rules": {
    "files": "warn",
    "exports": "warn",
    "types": "off",
    "duplicates": "off"
  }
}

{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "entry": ["src/app/**/*.{ts,tsx}", "src/pages/**/*.{ts,tsx}", "src/i18n/navigation.ts", "src/messages/migrate.ts!"],
  "project": ["src/**/*.{ts,tsx,mjs}"],
  "ignore": ["e2e/**/*", "scripts/**/*", "src/components/ui/**/*"],
  "ignoreDependencies": ["sharp", "shadcn"],
  "rules": {
    "files": "warn",
    "exports": "warn",
    "types": "off",
    "duplicates": "off"
  }
}

  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack",
    "dev-https": "next dev --experimental-https -p 443",
    "generate:api-types": "openapi-typescript ../api/openapi.json -o src/lib/api/generated/schema.ts",
    "generate:contracts": "bun run generate:api-types",
    "check:contracts": "node scripts/check_contracts.mjs",
    "i18n:consolidate": "bun run scripts/i18n-consolidate.ts",
    "test": "vitest run",
    "test:ui": "vitest --browser.enabled --browser.name=chromium",
    "test:browser": "vitest --browser.enabled",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "bun run lint:empty-folders && node scripts/check-markdown-migration.mjs && eslint . --cache",
    "lint:empty-folders": "node scripts/check-empty-folders.mjs",
    "lint:fix": "eslint --fix . --cache",
    "oxlint": "oxlint --type-aware --type-check --fix --fix-suggestions --fix-dangerously",
    "format": "oxfmt --write",
    "start": "next start",
    "check-types": "next typegen && tsgo --noEmit",
    "bundle:analyze": "next experimental-analyze",
    "knip": "knip"
  },

{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uv run app.py",
    "migrate": "uv run --no-sync alembic upgrade head",
    "format": "uv run ruff format",
    "lint": "uv run ruff check --fix --unsafe-fixes",
    "test": "uv run pytest",
    "generate:openapi": "uv run python scripts/export_openapi.py",
    "generate:contracts": "uv run python scripts/export_openapi.py"
  }
}
